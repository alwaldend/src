load("//tools/docs:defs.bzl", "docs_filegroup")

docs_filegroup(
    name = "docs",
    srcs = glob(["*.md"]),
    visibility = ["//third_party:__pkg__"],
    deps = subpackages(
        include = ["*"],
        allow_empty = True,
    ),
)

alias(
    name = "com_drawio_desktop_bin",
    actual = "@com_drawio_desktop_bin//:drawio_binary",
    visibility = ["//:__subpackages__"],
)

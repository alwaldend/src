load("//tools/docs:defs.bzl", "docs_filegroup")

docs_filegroup(
    name = "docs",
    srcs = glob(["*.md"]),
    visibility = ["//third_party:__pkg__"],
    deps = subpackages(
        include = ["*"],
        allow_empty = True,
    ),
)

alias(
    name = "org_codeberg_forgejo_contrib_forgejo_cli_bin",
    actual = "@org_codeberg_forgejo_contrib_forgejo_cli_bin//:fj_binary",
    visibility = ["//:__subpackages__"],
)

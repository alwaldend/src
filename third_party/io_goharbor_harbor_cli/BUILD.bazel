load("//tools/docs:defs.bzl", "docs_filegroup")

docs_filegroup(
    name = "docs",
    srcs = glob(["*.md"]),
    visibility = ["//third_party:__pkg__"],
    deps = subpackages(
        include = ["*"],
        allow_empty = True,
    ),
)

alias(
    name = "io_goharbor_harbor_cli",
    actual = "@io_goharbor_harbor_cli//:harbor_binary",
    visibility = ["//:__subpackages__"],
)

load("@bazel_skylib//rules:write_file.bzl", "write_file")
load("//projects/al/rules/al:al_binary.bzl", "al_binary_run_map")
load("//projects/al/rules/al:al_config.bzl", "al_config")
load("//tools/docs:defs.bzl", "docs_filegroup")

al_config(
    name = "al",
    srcs = ["al.lua"],
    visibility = ["//third_party:__subpackages__"],
    deps = ["//:al"],
)

docs_filegroup(
    name = "docs",
    srcs = glob(["*.md"]),
    visibility = ["//:__pkg__"],
    deps = subpackages(
        include = ["*"],
        allow_empty = True,
    ),
)

write_file(
    name = "publish_helm_script",
    out = "publish_helm_script.sh",
    content = [
        "#!/usr/bin/env sh",
        "set -eu",
        'for chart in "${@}"; do',
        'echo "Uploading ${chart}" >&2',
        'curl -H "Authorization: Bearer ${FORGEJO_API_TOKEN}" --fail -X POST --upload-file "${1}" "${FORGEJO_HOST}/api/packages/alwaldend/helm/api/charts"',
        "done",
    ],
    is_executable = True,
)

al_binary_run_map(
    name = "publish_helm",
    args = {
        "io_goharbor_helm_harbor": [
            "$(rootpath publish_helm_script)",
            "$(rootpath //third_party/io_goharbor_helm_harbor)",
        ],
    },
    configs = [
        ":al",
    ],
    data = [
        ":publish_helm_script",
        "//third_party/io_goharbor_helm_harbor",
        "//tools/vault/forgejo_login",
        "//tools/vault/injector",
    ],
    run_args = [
        "--plugin_label",
        "forgejo",
    ],
)

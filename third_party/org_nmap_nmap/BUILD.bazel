load("@rules_foreign_cc//foreign_cc:configure.bzl", "configure_make")
load("//tools/docs:defs.bzl", "docs_filegroup")

docs_filegroup(
    name = "docs",
    srcs = glob(["*.md"]),
    visibility = ["//third_party:__pkg__"],
    deps = subpackages(
        include = ["*"],
        allow_empty = True,
    ),
)

configure_make(
    name = "org_nmap_nmap",
    configure_in_place = True,
    lib_source = "@org_nmap_nmap",
    out_binaries = [
        "ncat",
        "nmap",
        "nping",
    ],
    visibility = ["//:__subpackages__"],
    deps = [
        "//third_party/net_zlib_zlib",
        "//third_party/org_openssl_openssl",
        "//third_party/org_pcre_pcre2",
    ],
)

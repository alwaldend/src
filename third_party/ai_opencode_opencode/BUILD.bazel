load("//tools/docs:defs.bzl", "docs_filegroup")

docs_filegroup(
    name = "docs",
    srcs = glob(["*.md"]),
    visibility = ["//third_party:__pkg__"],
    deps = subpackages(
        include = ["*"],
        allow_empty = True,
    ),
)

alias(
    name = "ai_opencode_opencode",
    actual = "@ai_opencode_opencode//:opencode_binary",
    visibility = ["//:__subpackages__"],
)

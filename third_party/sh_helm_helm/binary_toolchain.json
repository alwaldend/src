{
    "toolchains": [
        {
            "name": "helm",
            "version": "4.2.3"
        }
    ],
    "archives": [
        {
            "archive_name": "linux_x86_64",
            "toolchain_name": "helm",
            "toolchain_version": "4.2.3",
            "binaries": [
                {
                    "name": "helm",
                    "path": "out/helm"
                }
            ],
            "actions": [
                {
                    "download_and_extract": {
                        "url": "https://get.helm.sh/helm-v4.2.3-linux-amd64.tar.gz",
                        "output": "out",
                        "strip_prefix": "linux-amd64",
                        "integrity": "sha256-6biLTulbGMcGg5wo06AiDlvEcOnNkmJBDJB5PEX/i3w="
                    }
                }
            ],
            "rules": {
                "exec_compatible_with": [
                    "@platforms//os:linux",
                    "@platforms//cpu:x86_64"
                ]
            }
        }
    ]
}

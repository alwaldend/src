load("//tools/docs:defs.bzl", "docs_filegroup")

docs_filegroup(
    name = "docs",
    srcs = glob(["*.md"]),
    visibility = ["//third_party:__pkg__"],
    deps = subpackages(
        include = ["*"],
        allow_empty = True,
    ),
)

alias(
    name = "sh_helm_helm",
    actual = "@sh_helm_helm//:helm_binary",
    visibility = ["//:__subpackages__"],
)

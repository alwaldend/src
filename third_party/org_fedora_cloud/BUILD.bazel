load("//tools/docs:defs.bzl", "docs_filegroup")

docs_filegroup(
    name = "docs",
    srcs = glob(["*.md"]),
    visibility = ["//third_party:__pkg__"],
    deps = subpackages(
        include = ["*"],
        allow_empty = True,
    ),
)

alias(
    name = "org_fedora_cloud",
    actual = "@org_fedora_cloud//file",
    visibility = ["//:__subpackages__"],
)

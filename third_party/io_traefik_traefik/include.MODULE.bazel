binary_toolchain_extension = use_extension(
    "@rules_binary_toolchain//main/bzl:binary_toolchain_extension.bzl",
    "binary_toolchain_extension",
)
binary_toolchain_extension.toolchains(
    archives = {
        "traefik": ["linux_x86_64"],
    },
    lock = "//third_party/io_traefik_traefik:binary_toolchain.json",
    toolchains_map = {
        "traefik": "io_traefik_traefik",
    },
)

register_toolchains("@io_traefik_traefik//:all")

use_repo(
    binary_toolchain_extension,
    "io_traefik_traefik",
    "io_traefik_traefik_linux_x86_64",
)

load("@rules_pkg//pkg:mappings.bzl", "pkg_filegroup", "pkg_files")

pkg_filegroup(
    name = "docs",
    srcs = [
        ":docs_files",
        "//projects/alwaldend.com/content/docs",
    ],
    visibility = ["//projects/alwaldend.com:__pkg__"],
)

pkg_files(
    name = "docs_files",
    srcs = glob(["*.md"]),
    prefix = "content",
)

load("@rules_pkg//pkg:mappings.bzl", "pkg_filegroup", "pkg_files")

pkg_filegroup(
    name = "docs",
    srcs = [":docs_files"],
    visibility = ["//projects/ansible_collection:__pkg__"],
)

pkg_files(
    name = "docs_files",
    srcs = glob(["*.md"]),
    prefix = "content/docs/{}".format(package_name()),
)

pkg_files(
    name = "playbooks",
    srcs = glob(["*.yaml"]),
    prefix = "playbooks",
    visibility = ["//:__subpackages__"],
)

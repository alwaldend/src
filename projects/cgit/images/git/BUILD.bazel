load("@rules_oci//oci:defs.bzl", "oci_image")
load("@rules_pkg//pkg:mappings.bzl", "pkg_filegroup", "pkg_files")

pkg_filegroup(
    name = "docs",
    srcs = [":docs_files"],
    visibility = ["//projects/cgit/images:__pkg__"],
)

pkg_files(
    name = "docs_files",
    srcs = glob(["*.md"]) + [":image_index_json_cp"],
    prefix = "content/docs/{}".format(package_name()),
)

oci_image(
    name = "image",
    base = "@com_alwaldend_src_oci_alpine",
)

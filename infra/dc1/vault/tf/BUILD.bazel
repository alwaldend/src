load("//tools/docs:defs.bzl", "docs_filegroup")
load("//tools/terraform:defs.bzl", "terraform_runners")

docs_filegroup(
    name = "docs",
    srcs = glob(["*.md"]),
    visibility = ["//infra/dc1/vault:__pkg__"],
    deps = subpackages(
        include = ["*"],
        allow_empty = True,
    ),
)

terraform_runners(
    name = "tf",
    config = "//infra/dc1/vault:al",
    data = glob(["*.tf"]) + [
        ".terraform.lock.hcl",
        "//projects/tf_modules/backup_bucket",
        "//projects/tf_modules/tf_backend",
        "//projects/tf_modules/vault_approle",
    ],
    run_args = [
        "--vault_env",
        "default:default",
        "--secret_env",
        "tf_backend",
        "--secret_env",
        "yc_auth",
        "--secret_env",
        "yc_account",
        "--secret_env",
        "yc_bucket_auth",
    ],
)

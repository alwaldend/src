load("//tools/docs:defs.bzl", "docs_filegroup")
load("//tools/terraform:defs.bzl", "terraform_binary", "terraform_binary_map", "terraform_test_map")

docs_filegroup(
    name = "docs",
    srcs = glob(["*.md"]),
    visibility = ["//infra/dc1/consul1:__pkg__"],
    deps = subpackages(
        include = ["*"],
        allow_empty = True,
    ),
)

_CONFIGS = ["//infra/dc1/consul1:al"]

_RUN_ARGS = [
    "--env_vault",
    "default:default",
    "--env_label",
    "tf",
    "--service",
    "pve_login.bin=$(rootpath //tools/vault/pve_login)",
]

_DATA = glob(["*.tf"]) + [
    ".terraform.lock.hcl",
    "//tools/vault/pve_login",
    "//projects/tf_modules/pve_vm_qemu",
    "//infra/dc1/consul1:dnsconfig",
]

terraform_binary_map(
    name = "tf",
    configs = _CONFIGS,
    data = _DATA,
    run_args = _RUN_ARGS,
)

terraform_test_map(
    name = "tf_tests",
    configs = _CONFIGS,
    data = _DATA,
)

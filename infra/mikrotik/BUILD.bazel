load("//tools/docs:defs.bzl", "docs_filegroup")

filegroup(
    name = "dnsconfig",
    srcs = [
        "dnsconfig.json",
    ],
    visibility = ["//:__subpackages__"],
)

docs_filegroup(
    name = "docs",
    srcs = glob(["*.md"]) + glob(["*.rsc"]),
    visibility = ["//infra:__pkg__"],
    deps = subpackages(
        include = ["*"],
        allow_empty = True,
    ),
)

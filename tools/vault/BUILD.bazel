load("@rules_pkg//pkg:mappings.bzl", "pkg_filegroup", "pkg_files")
load("@com_alwaldend_src_tools_vault//:defs.bzl", "vault_binary")

vault_binary(
    name = "vault",
    env = {
        "VAULT_CACERT": "data/ssl/alwaldend.com_root_ca.crt",
        "VAULT_ADDR": "https://vault.dc1.alwaldend.com:8200"
    },
    data = ["//data/ssl:alwaldend.com_root_ca_crt"],
    visibility = ["//:__subpackages__"],
)

pkg_filegroup(
    name = "docs",
    srcs = [":docs_files"],
    visibility = ["//tools:__pkg__"],
)

pkg_files(
    name = "docs_files",
    srcs = glob(["*.md"]),
    prefix = "content/docs/{}".format(package_name()),
)

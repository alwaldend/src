load("@com_alwaldend_src_npm//tools:prettier/package_json.bzl", prettier = "bin")
load("@rules_pkg//pkg:mappings.bzl", "pkg_filegroup", "pkg_files")

prettier.prettier_binary(
    name = "prettier",
    visibility = ["//:__subpackages__"],
)

pkg_filegroup(
    name = "docs",
    srcs = [":docs_files"],
    visibility = ["//tools:__pkg__"],
)

pkg_files(
    name = "docs_files",
    srcs = glob(["*.md"]),
    prefix = "content/docs/{}".format(package_name()),
)

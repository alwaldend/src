load("@rules_pkg//pkg:mappings.bzl", "pkg_filegroup", "pkg_files")

alias(
    name = "shell_worker",
    actual = "//tools/shell_worker/main/go",
    visibility = ["//:__subpackages__"],
)

pkg_filegroup(
    name = "docs",
    srcs = [
        ":docs_files",
        "//tools/shell_worker/main/bzl:docs",
    ],
    visibility = ["//tools:__pkg__"],
)

pkg_files(
    name = "docs_files",
    srcs = glob(["*.md"]),
    prefix = "content/docs/{}".format(package_name()),
)

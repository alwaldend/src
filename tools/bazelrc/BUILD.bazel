load("@bazelrc-preset.bzl", "bazelrc_preset")
load("//tools/docs:defs.bzl", "docs_filegroup")

bazelrc_preset(
    name = "preset",
    strict = True,
)

docs_filegroup(
    name = "docs",
    srcs = glob(["*.md"]),
    visibility = ["//tools:__pkg__"],
    deps = subpackages(
        include = ["*"],
        allow_empty = True,
    ),
)

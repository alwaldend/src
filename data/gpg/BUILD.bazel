load("@rules_pkg//pkg:mappings.bzl", "pkg_filegroup", "pkg_files")

pkg_filegroup(
    name = "docs",
    srcs = [":docs_files"],
    visibility = ["//data:__pkg__"],
)

pkg_files(
    name = "docs_files",
    srcs = glob(["*.md"]) + [":openbao"],
    prefix = "content/docs/{}".format(package_name()),
)

filegroup(
    name = "openbao",
    srcs = ["openbao@lists.lfedge.org-pub-20240618.asc"],
    visibility = ["//:__subpackages__"],
)
